# ── Required ──────────────────────────────────────────────
# OpenRouter API key → https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Firecrawl API key → https://www.firecrawl.dev/
FIRECRAWL_API_KEY=your_firecrawl_api_key_here

ENABLE_GOOGLE_MAPS_SCRAPER=true

# ── Optional (if you want to swap search providers) ───────
# Tavily (better search results) → https://app.tavily.com/
TAVILY_API_KEY=your_tavily_api_key_here

# Serper (Google search API) → https://serper.dev/
SERPER_API_KEY=your_serper_api_key_here

# Mem0 API key (optional) → https://mem0.ai/
MEM0_API_KEY=your_mem0_api_key_here
